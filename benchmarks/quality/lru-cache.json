{
  "id": "lru-cache",
  "prompt": "Write Python: `LRUCache(capacity: int)` with `get(key) -> int` and `put(key, val)`. O(1) for both. Use only stdlib. Return -1 on cache miss.",
  "language": "python",
  "function": "LRUCache",
  "tests": [
    {
      "type": "sequence",
      "steps": [
        {"action": "init", "args": [2]},
        {"action": "call", "method": "put", "args": [1, 1], "expected": null},
        {"action": "call", "method": "put", "args": [2, 2], "expected": null},
        {"action": "call", "method": "get", "args": [1], "expected": 1},
        {"action": "call", "method": "put", "args": [3, 3], "expected": null},
        {"action": "call", "method": "get", "args": [2], "expected": -1},
        {"action": "call", "method": "put", "args": [4, 4], "expected": null},
        {"action": "call", "method": "get", "args": [1], "expected": -1},
        {"action": "call", "method": "get", "args": [3], "expected": 3},
        {"action": "call", "method": "get", "args": [4], "expected": 4}
      ]
    }
  ],
  "quality_checks": {
    "max_lines": 30,
    "banned_patterns": ["import functools", "@lru_cache"],
    "required_patterns": ["class LRUCache", "def get", "def put"]
  }
}
